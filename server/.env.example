# Django
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Signed playback tokens (seconds)
PLAYBACK_TOKEN_TTL_SECONDS=60

# HLS signed tokens (seconds)
HLS_TOKEN_TTL_SECONDS=300

# Where HLS outputs are written under MEDIA_ROOT
HLS_OUTPUT_SUBDIR=hls

# Postgres (enable by setting POSTGRES_HOST)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=elearning
POSTGRES_USER=elearning
POSTGRES_PASSWORD=elearning

# Redis (enable caching by setting REDIS_URL)
REDIS_URL=redis://127.0.0.1:6379/1
